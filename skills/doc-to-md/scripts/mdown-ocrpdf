#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
DEFAULT_SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
DOC_TO_MD_SKILL_DIR="${DOC_TO_MD_SKILL_DIR:-$DEFAULT_SKILL_DIR}"
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
DOC_TO_MD_TOOLS_DIR="${DOC_TO_MD_TOOLS_DIR:-$CODEX_HOME_DIR/tools}"
OCR_VENV="${DOC_TO_MD_OCR_VENV:-$DOC_TO_MD_TOOLS_DIR/doc-to-md-ocr-venv}"
OCR_PYTHON="${DOC_TO_MD_OCR_PYTHON:-$OCR_VENV/bin/python}"
OCR_SCRIPT="${DOC_TO_MD_OCR_SCRIPT:-$DOC_TO_MD_SKILL_DIR/scripts/mdown_ocrpdf.py}"
runtime_requirements="$OCR_VENV/.doc-to-md-requirements"
if [[ -z "${DOC_TO_MD_OCR_REQUIREMENTS:-}" && -f "$runtime_requirements" ]]; then
  DOC_TO_MD_OCR_REQUIREMENTS="$(<"$runtime_requirements")"
fi
OCR_REQUIREMENTS="${DOC_TO_MD_OCR_REQUIREMENTS:-$DOC_TO_MD_SKILL_DIR/requirements-ocr.lock.txt}"
export DOC_TO_MD_OCR_REQUIREMENTS="$OCR_REQUIREMENTS"

if [[ ! -x "$OCR_PYTHON" ]]; then
  printf 'mdown-ocrpdf: OCR workflow Python not found at %s\n' "$OCR_PYTHON" >&2
  printf 'Rebuild with: python3 -m venv %q && %q -m pip install -r %q\n' \
    "$OCR_VENV" "$OCR_VENV/bin/python" "$OCR_REQUIREMENTS" >&2
  exit 127
fi

exec "$OCR_PYTHON" "$OCR_SCRIPT" "$@"
