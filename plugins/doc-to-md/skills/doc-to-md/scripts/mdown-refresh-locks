#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
DEFAULT_SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
DOC_TO_MD_SKILL_DIR="${DOC_TO_MD_SKILL_DIR:-$DEFAULT_SKILL_DIR}"
SCRIPT="${DOC_TO_MD_REFRESH_LOCKS_SCRIPT:-$DOC_TO_MD_SKILL_DIR/scripts/refresh-locks.py}"
PYTHON_BIN="${PYTHON:-python3}"

if [[ ! -f "$SCRIPT" ]]; then
  printf 'mdown-refresh-locks: refresh script not found: %s\n' "$SCRIPT" >&2
  printf 'Run from a checked-out skill source with: python3 scripts/refresh-locks.py\n' >&2
  exit 127
fi

exec "$PYTHON_BIN" "$SCRIPT" "$@"
