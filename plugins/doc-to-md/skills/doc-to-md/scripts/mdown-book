#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
DEFAULT_SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
DOC_TO_MD_SKILL_DIR="${DOC_TO_MD_SKILL_DIR:-$DEFAULT_SKILL_DIR}"
DOC_TO_MD_BIN_DIR="${DOC_TO_MD_BIN_DIR:-$HOME/.local/bin}"
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
DOC_TO_MD_TOOLS_DIR="${DOC_TO_MD_TOOLS_DIR:-$CODEX_HOME_DIR/tools}"
BOOK_VENV="${DOC_TO_MD_BOOK_VENV:-$DOC_TO_MD_TOOLS_DIR/doc-to-md-book-venv}"
BOOK_PYTHON="${DOC_TO_MD_BOOK_PYTHON:-$BOOK_VENV/bin/python}"
BOOK_SCRIPT="${DOC_TO_MD_BOOK_SCRIPT:-$DOC_TO_MD_SKILL_DIR/scripts/mdown_book.py}"
runtime_requirements="$BOOK_VENV/.doc-to-md-requirements"
if [[ -z "${DOC_TO_MD_BOOK_REQUIREMENTS:-}" && -f "$runtime_requirements" ]]; then
  DOC_TO_MD_BOOK_REQUIREMENTS="$(<"$runtime_requirements")"
fi
BOOK_REQUIREMENTS="${DOC_TO_MD_BOOK_REQUIREMENTS:-$DOC_TO_MD_SKILL_DIR/requirements-book.txt}"
MDOWN_BIN="${MDOWN_BIN:-$DOC_TO_MD_BIN_DIR/mdown}"
export DOC_TO_MD_BOOK_REQUIREMENTS="$BOOK_REQUIREMENTS"
export MDOWN_BIN

if [[ ! -x "$BOOK_PYTHON" ]]; then
  printf 'mdown-book: book workflow Python not found at %s\n' "$BOOK_PYTHON" >&2
  printf 'Rebuild with: python3 -m venv %q && %q -m pip install -r %q\n' \
    "$BOOK_VENV" "$BOOK_VENV/bin/python" "$BOOK_REQUIREMENTS" >&2
  exit 127
fi

exec "$BOOK_PYTHON" "$BOOK_SCRIPT" "$@"
